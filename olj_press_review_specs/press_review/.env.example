# OLJ Press Review — Environment Variables
# Copy to .env and fill in real values

# PostgreSQL (Railway provides DATABASE_URL automatically)
DATABASE_URL=postgresql+asyncpg://postgres:password@localhost:5432/press_review

# Anthropic API (required)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# OpenAI API (for embeddings — optional for MVP)
OPENAI_API_KEY=sk-xxxxx

# Models
TRANSLATION_MODEL=claude-haiku-4-5-20251001
FORMATTING_MODEL=claude-sonnet-4-5-20241022
EMBEDDING_MODEL=text-embedding-3-small

# Collection
COLLECTION_HOUR_UTC=6
MAX_ARTICLES_PER_SOURCE=20
REQUEST_DELAY_SECONDS=1.5

# Processing
MIN_ARTICLE_LENGTH=200
TRANSLATION_CONFIDENCE_THRESHOLD=0.7

# Infrastructure
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=INFO
