# --- Mode API ---
# direct = appel navigateur vers FastAPI (NEXT_PUBLIC_API_URL)
# proxy = BFF Next /api/proxy/* (clé INTERNAL_API_KEY côté serveur uniquement)
NEXT_PUBLIC_API_MODE=direct
NEXT_PUBLIC_API_URL=http://localhost:8000

# En mode direct seulement (exposé au navigateur — éviter en prod publique)
# NEXT_PUBLIC_API_KEY=  # Authorization: Bearer … (même valeur que INTERNAL_API_KEY backend)
# NEXT_PUBLIC_INTERNAL_API_KEY=  # alias supporté si NEXT_PUBLIC_API_KEY absent
NEXT_PUBLIC_EDITOR_ID=

# --- Clustering (info) — le backend lit CLUSTERING_USE_UMAP (défaut true). Railway : aligner avec la spec Sprint 4.

# --- Variables serveur Next (mode proxy) : ne pas préfixer NEXT_PUBLIC ---
# BACKEND_INTERNAL_URL=http://127.0.0.1:8000
# INTERNAL_API_KEY=même valeur que INTERNAL_API_KEY du backend
