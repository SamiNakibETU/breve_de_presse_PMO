# PostgreSQL (docker-compose default)
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/press_review
# Railway : pour `railway run alembic` depuis ton PC, l’URL interne ne résout pas en DNS.
# Dans le dashboard Postgres → Connect → copier l’URL « Public » et l’exposer au service backend :
# DATABASE_PUBLIC_URL=postgresql://postgres:...@xxx.proxy.rlwy.net:12345/railway

# ─── Embeddings (obligatoire pour pipeline : embed + clustering sémantique) ───
COHERE_API_KEY=

# ─── LLM Provider API Keys (set at least one) ───
# Groq: fast & cheap for EN/FR translation + OLJ generation
GROQ_API_KEY=gsk_xxxxx
# Cerebras: fast & cheap for AR/FA/TR/KU translation
CEREBRAS_API_KEY=csk-xxxxx
# Anthropic: fallback + Hebrew translation (only reliable provider for Hebrew)
ANTHROPIC_API_KEY=sk-ant-api03-xxxxx

# ─── Model overrides (defaults shown — change only if needed) ───
# GROQ_TRANSLATION_MODEL=meta-llama/llama-4-scout-17b-16e-instruct
# GROQ_GENERATION_MODEL=llama-3.3-70b-versatile
# CEREBRAS_TRANSLATION_MODEL=qwen-3-235b-a22b
# ANTHROPIC_TRANSLATION_MODEL=claude-haiku-4-5-20241022
# ANTHROPIC_GENERATION_MODEL=claude-sonnet-4-5-20241022
# Cache prompt system Anthropic (réduit le coût des appels répétés)
# ANTHROPIC_USE_PROMPT_CACHE=true

# Collection
COLLECTION_HOUR_UTC=6
MAX_ARTICLES_PER_SOURCE=20
REQUEST_DELAY_SECONDS=1.5

# Clustering (MEMW Sprint 4 — UMAP 15D avant HDBSCAN ; défaut true)
# CLUSTERING_USE_UMAP=true
# UMAP_N_NEIGHBORS=15
# UMAP_N_COMPONENTS=15
# Fusion post-HDBSCAN : seuil cosinus centroïdes (défaut 0.88 ; 0.80 trop agressif → méga-clusters)
# CLUSTER_MERGE_CENTROID_COSINE=0.88

# Logs structurés (Railway / audit : chercher hdbscan.result, clustering.umap_failed_fallback)
# LOG_JSON=true
# LOG_LEVEL=INFO

# Processing
MIN_ARTICLE_LENGTH=200
TRANSLATION_CONFIDENCE_THRESHOLD=0.7

# ─── MEMW v2 : corps FR complet, analyse experte, cascade scraping (Railway) ───
# STORE_FULL_TRANSLATION_FR=true — persiste content_translated_fr (coût tokens accru)
# ENHANCED_SCRAPER_ENABLED=true — dernier repli cascade (aiohttp → curl_cffi → Playwright → …)
# ARTICLE_ANALYSIS_ENABLED=true — bullets + thèse post-traduction (Haiku/Sonnet selon config)
# ARTICLE_ANALYSIS_BATCH_LIMIT=120
# AUTO_TRANSLATE_SELECTED_ARTICLES=true — job périodique : corps complet pour sélections
# FORCE_FULL_TRANSLATION_FOR_SELECTED=true — ignore résumé seul EN pour la rétention
# SELECTED_FULL_TRANSLATION_BATCH_LIMIT=15
# SELECTED_FULLTEXT_JOB_INTERVAL_MINUTES=5
# Fenêtre produit : 0 = désactive le filtre (tests / file ancienne)
# TRANSLATION_AUTO_MAX_AGE_DAYS=14
# INGESTION_RSS_ENTRY_MAX_AGE_DAYS=7
# Plafond débit traduction par passage (après filtre fraîcheur)
# TRANSLATION_PIPELINE_BATCH_LIMIT=300

# Auth mutations (POST/PUT/PATCH/DELETE) — si défini, exige Authorization: Bearer …
# INTERNAL_API_KEY=

# Infrastructure
PORT=8000
ENVIRONMENT=development
LOG_LEVEL=DEBUG
# URL du frontend (CORS). En staging/prod : https://votre-frontend.up.railway.app
FRONTEND_URL=http://localhost:3000
# Origines CORS supplémentaires, séparées par des virgules (previews, autre domaine)
# CORS_ORIGINS=https://frontendpmo-staging.up.railway.app
